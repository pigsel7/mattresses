    "nodemailer": "^8.0.10",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^8.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2"
