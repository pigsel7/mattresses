generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum AttributeType {
  STRING
  NUMBER
  BOOLEAN
  SELECT
  MULTI_SELECT
}

enum OrderStatus {
  NEW
  PROCESSING
  COMPLETED
  CANCELLED
}

enum ProductImageRole {
  MAIN
  GALLERY
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum UserType {
  USER
  ADMIN
}

model Category {
  id          String                @id @default(cuid())
  slug        String                @unique
  name        String
  description String?
  imageUrl    String?
  sortOrder   Int                   @default(0)
  parentId    String?
  parent      Category?             @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[]            @relation("CategoryTree")
  attributes  AttributeDefinition[]
  products    Product[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([parentId])
  @@index([sortOrder])
}

model AttributeDefinition {
  id           String                  @id @default(cuid())
  key          String
  label        String
  type         AttributeType
  unit         String?
  isRequired   Boolean                 @default(false)
  isFilterable Boolean                 @default(false)
  sortOrder    Int                     @default(0)
  categoryId   String
  category     Category                @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  options      AttributeOption[]
  values       ProductAttributeValue[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([categoryId, key])
  @@index([categoryId])
  @@index([categoryId, isFilterable])
}

model AttributeOption {
  id          String                  @id @default(cuid())
  value       String
  label       String
  sortOrder   Int                     @default(0)
  attributeId String
  attribute   AttributeDefinition     @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  values      ProductAttributeValue[] @relation("SelectedAttributeOption")
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@unique([attributeId, value])
  @@index([attributeId])
  @@index([sortOrder])
}

model Product {
  id              String                  @id @default(cuid())
  slug            String                  @unique
  title           String
  description     String?
  price           Decimal                 @db.Decimal(12, 2)
  currency        String                  @default("RUB")
  sku             String?                 @unique
  status          ProductStatus           @default(ACTIVE)
  stockQuantity   Int                     @default(0)
  categoryId      String
  category        Category                @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images          ProductImage[]
  attributeValues ProductAttributeValue[]
  orderItems      OrderItem[]
  pageViews       PageView[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([categoryId, status])
  @@index([createdAt])
}

model ProductImage {
  id        String           @id @default(cuid())
  url       String
  alt       String?
  role      ProductImageRole @default(GALLERY)
  sortOrder Int              @default(0)
  productId String
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([productId, sortOrder])
  @@index([productId])
  @@index([role])
}

model ProductAttributeValue {
  id               String               @id @default(cuid())
  productId        String
  attributeId      String
  valueString      String?
  valueNumber      Decimal?             @db.Decimal(14, 4)
  valueBoolean     Boolean?
  valueJson        Json?
  selectedOptionId String?
  product          Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute        AttributeDefinition  @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  selectedOption   AttributeOption?     @relation("SelectedAttributeOption", fields: [selectedOptionId], references: [id], onDelete: SetNull)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([productId, attributeId])
  @@index([attributeId])
  @@index([selectedOptionId])
  @@index([valueNumber])
  @@index([valueBoolean])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  status          OrderStatus @default(NEW)
  customerName    String
  customerPhone   String
  customerEmail   String?
  deliveryAddress String
  comment         String?
  totalAmount     Decimal     @db.Decimal(12, 2)
  currency        String      @default("RUB")
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
  @@index([customerPhone])
  @@index([customerEmail])
  @@index([createdAt])
}

model OrderItem {
  id                  String   @id @default(cuid())
  quantity            Int
  unitPrice           Decimal  @db.Decimal(12, 2)
  totalPrice          Decimal  @db.Decimal(12, 2)
  productSnapshotName String
  productSnapshotSku  String?
  productSnapshotSlug String?
  orderId             String
  productId           String?
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}

model AdminUser {
  id                  String                   @id @default(cuid())
  email               String                   @unique
  name                String?
  phone               String?
  passwordHash        String
  role                AdminRole                @default(ADMIN)
  userType            UserType                 @default(USER)
  isActive            Boolean                  @default(true)
  emailVerifiedAt     DateTime?
  lastLoginAt         DateTime?
  verificationTokens  EmailVerificationToken[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([isActive])
  @@index([userType])
  @@index([emailVerifiedAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model ShopSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String?
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublic])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([path])
  @@index([productId])
  @@index([createdAt])
}
