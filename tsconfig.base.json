{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/frontend/src/*"],
      "@mattress/config": ["packages/config/src"],
      "@mattress/config/*": ["packages/config/src/*"],
      "@mattress/shared": ["packages/shared/src"],
      "@mattress/shared/*": ["packages/shared/src/*"],
      "@mattress/ui": ["packages/ui/src"],
      "@mattress/ui/*": ["packages/ui/src/*"]
    },
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  }
}
